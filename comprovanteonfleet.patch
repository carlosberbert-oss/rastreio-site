@@ -575,6 +612,37 @@
       addrEl.style.display = "none";
     }
 
+    // Comprovante de entrega Onfleet (fotos + assinatura)
+    const proofEl    = document.getElementById("onfleetProof");
+    const fotosEl    = document.getElementById("proofFotos");
+    const assEl      = document.getElementById("proofAssinatura");
+    const fotos      = (ehOnfleet && Array.isArray(data.fotos)) ? data.fotos : [];
+    const assinatura = ehOnfleet ? (data.assinatura || "") : "";
+
+    fotosEl.innerHTML = "";
+    fotos.forEach((url, i) => {
+      const img = document.createElement("img");
+      img.src = url;
+      img.alt = "Foto da entrega " + (i + 1);
+      img.loading = "lazy";
+      img.addEventListener("click", () => abrirLightbox(url));
+      // Se o id for inválido/expirado e a imagem não carregar, remove do grid.
+      img.addEventListener("error", () => img.remove());
+      fotosEl.appendChild(img);
+    });
+
+    if (assinatura) {
+      const assImg = document.getElementById("proofAssinaturaImg");
+      assImg.src = assinatura;
+      assImg.onclick = () => abrirLightbox(assinatura);
+      assImg.onerror = () => { assEl.style.display = "none"; };
+      assEl.style.display = "";
+    } else {
+      assEl.style.display = "none";
+    }
+
+    proofEl.style.display = (fotos.length || assinatura) ? "" : "none";
+
     // Botão comprovante SSW
