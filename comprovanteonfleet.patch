   }
   .onfleet-addr svg { width: 16px; height: 16px; flex-shrink: 0; margin-top: 1px; color: var(--onfleet); }
 
+  /* Comprovante de entrega Onfleet (fotos + assinatura) */
+  .onfleet-proof { margin-top: 18px; padding: 16px 18px; background: rgba(107,63,160,0.06);
+    border: 1px solid rgba(107,63,160,0.14); border-radius: 13px; }
+  .proof-title { font-size: 12px; text-transform: uppercase; color: var(--fg-3);
+    letter-spacing: 0.06em; font-weight: 600; margin-bottom: 14px; }
+  .proof-fotos { display: grid; grid-template-columns: repeat(auto-fill, minmax(96px, 1fr)); gap: 10px; }
+  .proof-fotos img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 10px;
+    border: 1px solid var(--divider); cursor: zoom-in; background: var(--bg-3);
+    transition: transform .18s var(--ease), box-shadow .18s var(--ease); }
+  .proof-fotos img:hover { transform: scale(1.03); box-shadow: var(--shadow); }
+  .proof-assinatura { margin-top: 16px; }
+  .proof-sub { font-size: 11px; text-transform: uppercase; color: var(--fg-3);
+    letter-spacing: 0.05em; font-weight: 600; margin-bottom: 8px; }
+  .proof-assinatura img { max-width: 220px; width: 100%; border-radius: 10px;
+    border: 1px solid var(--divider); background: #fff; cursor: zoom-in; }
+
+  /* Lightbox (ampliar comprovante) */
+  .lightbox { position: fixed; inset: 0; z-index: 999; display: flex; align-items: center;
+    justify-content: center; padding: 24px; background: rgba(11,34,57,0.82);
+    backdrop-filter: blur(3px); cursor: zoom-out; animation: pop 220ms var(--ease-out); }
+  .lightbox img { max-width: 100%; max-height: 100%; border-radius: 12px; box-shadow: var(--shadow-lg); }
+
   .error-card { background: rgba(214,69,69,0.06); border: 1px solid rgba(214,69,69,0.26); border-radius: 14px; padding: 18px 20px; color: var(--danger); font-size: 14px; line-height: 1.5; font-weight: 500; margin-top: 24px; display: none; }
   .error-card.visible { display: block; animation: pop 320ms var(--ease-out); }
 
